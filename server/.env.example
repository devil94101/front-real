# ─── Stackline Server Configuration ───
PORT=3001
API_PREFIX=/api
CORS_ORIGIN=*

# TODO: set these to long random strings in any real environment.
JWT_SECRET=
JWT_REFRESH_SECRET=
JWT_EXPIRES_IN=1h
JWT_REFRESH_EXPIRES_IN=30d

# Password for the pre-seeded demo broker accounts.
SEED_PASSWORD=demo1234

# ── Razorpay (premium subscriptions) ──
# Leave blank for MOCK mode; fill to enable live payments. TODO: provide before production.
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_PLAN_ID=
RAZORPAY_WEBHOOK_SECRET=

# ── Plan limits & pricing ──
FREE_PROPERTY_LIMIT=10
PREMIUM_PROPERTY_LIMIT=100
PREMIUM_AMOUNT=499900
PREMIUM_CURRENCY=INR
PREMIUM_PERIOD=yearly
PREMIUM_INTERVAL=1
PREMIUM_TOTAL_COUNT=5
